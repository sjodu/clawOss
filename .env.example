# ClawOSS V11 Environment Configuration
# Copy to .env and fill in your values
# DO NOT COMMIT .env — it is gitignored

# ===== LLM Configuration (Required) =====
# Supports: openai, anthropic, deepseek, openrouter, azure, or any OpenAI-compatible API

# Provider and model
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1

# Model parameters (optional, defaults shown)
LLM_CONTEXT_WINDOW=128000
LLM_MAX_TOKENS=4096

# Cost configuration (per million tokens, in USD)
LLM_COST_INPUT=0.15
LLM_COST_OUTPUT=0.6

# ===== Budget Control (Required) =====
BUDGET_MAX_USD=10.0

# ===== GitHub Configuration (Required) =====
# Personal Access Token — needs public_repo scope
GITHUB_TOKEN=ghp_your-token-here

# GitHub identity for PRs (optional, defaults shown)
GITHUB_USERNAME=BillionClaw
GITHUB_EMAIL=billionclaw+clawoss@users.noreply.github.com

# ===== Dashboard (Optional) =====
DASHBOARD_URL=https://clawoss-dashboard.vercel.app
CLAW_API_KEY=your-dashboard-api-key-here

# ===== Example Configurations =====

# --- OpenAI GPT-4 Turbo ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4-turbo
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_COST_INPUT=10.0
# LLM_COST_OUTPUT=30.0

# --- OpenAI GPT-4o ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_COST_INPUT=2.5
# LLM_COST_OUTPUT=10.0

# --- Anthropic Claude 3.5 Sonnet ---
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_API_KEY=sk-ant-xxx
# LLM_BASE_URL=https://api.anthropic.com
# LLM_CONTEXT_WINDOW=200000
# LLM_MAX_TOKENS=8192
# LLM_COST_INPUT=3.0
# LLM_COST_OUTPUT=15.0

# --- DeepSeek Chat ---
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_CONTEXT_WINDOW=64000
# LLM_COST_INPUT=0.14
# LLM_COST_OUTPUT=0.28

# --- OpenRouter (any model) ---
# LLM_PROVIDER=openrouter
# LLM_MODEL=anthropic/claude-3.5-sonnet
# LLM_API_KEY=sk-or-xxx
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_CONTEXT_WINDOW=200000
# LLM_COST_INPUT=3.0
# LLM_COST_OUTPUT=15.0

# --- Azure OpenAI ---
# LLM_PROVIDER=azure
# LLM_MODEL=gpt-4-turbo
# LLM_API_KEY=your-azure-key
# LLM_BASE_URL=https://your-resource.openai.azure.com
# LLM_COST_INPUT=10.0
# LLM_COST_OUTPUT=30.0

